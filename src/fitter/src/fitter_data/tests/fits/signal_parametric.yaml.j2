{% set brems = [1, 2] %}
{% set blocks = range(1, 3) %}

output_directory : rare/rk/electron/signal 
categories:
{% for brem in brems %}
{% for block in blocks %}
  brem_xx{{brem}}_b{{block}}:
    selection:
      block       : block == {{block}}
      brem{{brem}}: nbrem == {{brem}}
    model:
      - dscb
{% endfor %}
{% endfor %}
sample        : Bu_Kee_eq_btosllball05_DPC
shared        :
  - mu
  - sg
float         : []
reparametrize :
  mu : scale
  sg : reso
fix           : {}
fit:
  strategy  :
    retry   :
      ntries        : 10
      pvalue_thresh : 0.05
      ignore_status : false 
plots: # These entries should be taken from https://gitlab.cern.ch/rx_run3/dmu#fit-plotting
  nbins   : 30
  stacked : true
